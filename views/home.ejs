<%- include('partials_header') %>

<section class="hero">
  <div class="container">
    <h1>Southern Bobby-Q Catering</h1>
    <p>The trusted caterer for USPSA matches and special events &mdash; slow-smoked classics and made-to-order menus, from hot dogs to prime rib.</p>
    <a href="/contact" class="btn">Request Catering</a>
  </div>
</section>

<section class="container">
  <div class="feature-strip">
    <div class="feature-card">
      <span class="feature-icon">🎯</span>
      <h3>Trusted at the Range</h3>
      <p>Match-day catering for USPSA clubs, sections, and state championships.</p>
    </div>
    <div class="feature-card">
      <span class="feature-icon">🔥</span>
      <h3>Low &amp; Slow</h3>
      <p>Smoked overnight with house-made rubs and sauces for real Southern flavor.</p>
    </div>
    <div class="feature-card">
      <span class="feature-icon">🍽️</span>
      <h3>Hot Dogs to Prime Rib</h3>
      <p>We build the menu around your event &mdash; casual match-day fare or a formal plated dinner.</p>
    </div>
  </div>
</section>

<section class="container">
  <blockquote class="testimonial">
    <p>&ldquo;Southern Bobby-Q Catering supports the Shooting Sports. You cannot get a better meal at a sporting event.&rdquo;</p>
    <cite>&mdash; Brian Conley</cite>
  </blockquote>
</section>

<section class="container">
  <h2>Upcoming Events</h2>
  <% if (upcomingEvents.length === 0) { %>
    <p>No events scheduled right now &mdash; check back soon!</p>
  <% } else { %>
    <ul class="event-list">
      <% upcomingEvents.forEach(function(ev) { %>
        <% const d = new Date(ev.event_date); %>
        <li class="event-card">
          <div class="date-badge">
            <span class="day"><%= d.getDate() %></span>
            <span class="mon"><%= d.toLocaleDateString('en-US', { month: 'short' }) %></span>
          </div>
          <div class="event-body">
            <strong><%= ev.title %></strong>
            <span><%= d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %><% if (ev.start_time) { %> &middot; <%= ev.start_time %><% } %></span>
            <% if (ev.location) { %><span><%= ev.location %></span><% } %>
          </div>
        </li>
      <% }) %>
    </ul>
    <p><a href="/events">See all events &rarr;</a></p>
  <% } %>
</section>

<%- include('partials_footer') %>
