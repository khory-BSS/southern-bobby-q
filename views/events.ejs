<%- include('partials_header') %>

<section class="container">
  <h1>Upcoming Events</h1>
  <% if (events.length === 0) { %>
    <p>No events scheduled right now &mdash; check back soon!</p>
  <% } else { %>
    <ul class="event-list">
      <% events.forEach(function(ev) { %>
        <% const d = new Date(ev.event_date); %>
        <li class="event-card">
          <div class="date-badge">
            <span class="day"><%= d.getDate() %></span>
            <span class="mon"><%= d.toLocaleDateString('en-US', { month: 'short' }) %></span>
          </div>
          <div class="event-body">
            <strong><%= ev.title %></strong>
            <span><%= d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) %><% if (ev.start_time) { %> &middot; <%= ev.start_time %><% } %></span>
            <% if (ev.location) { %><span><%= ev.location %></span><% } %>
            <% if (ev.description) { %><p><%= ev.description %></p><% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include('partials_footer') %>
