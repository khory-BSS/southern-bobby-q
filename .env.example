# Railway provides this automatically once you add a Postgres service - you don't need to set it manually
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Any random long string - used to sign login sessions
SESSION_SECRET=change-this-to-something-random

# Admin login credentials
ADMIN_USERNAME=admin
# Generate this with: node generate-password-hash.js yourpassword
ADMIN_PASSWORD_HASH=
